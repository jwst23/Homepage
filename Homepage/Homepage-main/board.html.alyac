<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>강지우 | 커뮤니티 게시판</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+KR:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/style.css">
    <!-- GSAP for animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script type="module" src="js/firebase-board.js"></script>
</head>
<body style="overflow-y: auto;">
    <div class="custom-cursor" id="custom-cursor"></div>
    <div class="noise-overlay"></div>
    
    <header class="header">
        <div class="logo">
            <a href="index.html" style="text-decoration:none; color:inherit; display:flex; align-items:center; gap:0.8rem;">
                <span class="logo-mark">JW</span> KANG JI-WOO
            </a>
        </div>
        <nav class="nav">
            <ul>
                <li><a href="index.html">홈으로</a></li>
            </ul>
        </nav>
    </header>

    <div class="board-wrapper">
        <h1 class="board-header">Community Board</h1>
        
        <form id="write-form" class="board-form">
            <input type="text" id="post-title" placeholder="제목을 입력하세요" required>
            <input type="text" id="post-author" placeholder="작성자" required>
            <textarea id="post-content" rows="4" placeholder="내용을 입력하세요" required></textarea>
            <button type="submit">게시글 작성</button>
        </form>

        <ul id="post-list" class="post-list">
            <!-- Posts will be loaded here dynamically -->
        </ul>
    </div>
    <script src="js/main.js"></script>
</body>
</html>
